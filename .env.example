# NoMoreAISlop Environment Variables
# Copy this file to .env and fill in your values

# Required: Gemini key for the local analysis pipeline
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Anthropic fallback / legacy paths
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: local-first configuration
# NOSLOP_MODEL=claude-sonnet-4-20250514
# NOSLOP_TELEMETRY=false
# NOSLOP_BASE_URL=http://localhost:3000
# NOSLOP_WEB_APP_URL=http://localhost:3000

# ============================================
# Testing & Development
# ============================================

# Override user tier for testing all features locally
# Values: free, pro, premium, enterprise
# NOSLOP_TEST_TIER=enterprise
