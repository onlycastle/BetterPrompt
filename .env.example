# NoMoreAISlop Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required for analysis)
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Override default model
# NOSLOP_MODEL=claude-sonnet-4-5-20241022

# Optional: Disable telemetry
# NOSLOP_TELEMETRY=false

# ============================================
# Supabase Configuration
# ============================================

# Supabase Project URL (from Project Settings > API)
# NOTE: NEXT_PUBLIC_ prefix is required for client-side access
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key (public, safe for client-side)
# NOTE: NEXT_PUBLIC_ prefix is required for client-side access
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (secret, server-side only!)
# WARNING: Never expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Polar.sh Configuration (Payment & Licensing)
# Get these from https://polar.sh/dashboard
# ============================================

# Polar API Access Token (from Settings > Access Tokens)
POLAR_ACCESS_TOKEN=polar_at_xxx

# Polar Webhook Secret (from Settings > Webhooks)
POLAR_WEBHOOK_SECRET=whsec_xxx

# Polar Organization ID (from Organization Settings)
POLAR_ORGANIZATION_ID=org_xxx

# ============================================
# Application Configuration
# ============================================

# Base URL for share links (production domain)
NOSLOP_BASE_URL=https://www.nomoreaislop.xyz

# ============================================
# Slack Notifications
# ============================================

# Slack Incoming Webhook URL for notifications (signups, waitlist, etc.)
# Get this from: https://api.slack.com/apps → Create New App → Incoming Webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# ============================================
# Testing & Development (DO NOT USE IN PRODUCTION)
# ============================================

# Override user tier for testing all features locally
# Values: free, pro, premium, enterprise
# WARNING: Only works when NODE_ENV != 'production'
# NOSLOP_TEST_TIER=enterprise
