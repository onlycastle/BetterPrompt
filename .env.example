# BetterPrompt Environment Variables
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────

# Gemini API key for the multi-phase analysis pipeline
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here

# ──────────────────────────────────────────────
# Optional: Server Configuration
# ──────────────────────────────────────────────

# Base URL for report links and CLI display (default: http://localhost:3000)
# BETTERPROMPT_BASE_URL=http://localhost:3000
# BETTERPROMPT_WEB_APP_URL=http://localhost:3000

# SQLite database location (default: ~/.betterprompt/betterprompt.db)
# BETTERPROMPT_DB_PATH=~/.betterprompt/betterprompt.db

# ──────────────────────────────────────────────
# Optional: Plugin Configuration
# ──────────────────────────────────────────────

# Server URL for plugin API calls (default: http://localhost:3000)
# BETTERPROMPT_SERVER_URL=http://localhost:3000

# Auth token for plugin API requests
# BETTERPROMPT_AUTH_TOKEN=

# Auto-analyze after session ends (default: true)
# BETTERPROMPT_AUTO_ANALYZE=true

# Minimum sessions before auto-analysis triggers (default: 5)
# BETTERPROMPT_ANALYZE_THRESHOLD=5

# ──────────────────────────────────────────────
# Optional: Session Source Directories
# ──────────────────────────────────────────────

# Claude projects directory (default: ~/.claude/projects)
# CLAUDE_PROJECTS_DIR=~/.claude/projects

# Cursor chats directory (default: ~/.cursor/chats)
# CURSOR_CHATS_DIR=~/.cursor/chats

# ──────────────────────────────────────────────
# Optional: Development / Debug
# ──────────────────────────────────────────────

# Enable verbose debug logging (set to "1")
# BETTERPROMPT_DEBUG=1

# Enable prompt pattern debug output
# DEBUG_PROMPT_PATTERNS=1

# Disable telemetry
# BETTERPROMPT_TELEMETRY=false
