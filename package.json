{
  "name": "betterprompt-server",
  "version": "1.1.0",
  "description": "Self-hosted AI session analysis with a local-first CLI and Next.js server",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "tsx scripts/analyze-style.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "collaboration",
    "ai-builders",
    "productivity",
    "analysis"
  ],
  "author": "BetterPrompt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/onlycastle/BetterPrompt"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.45.0",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/analytics": "^1.6.1",
    "better-sqlite3": "^11.0.0",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "next": "^15.5.9",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wrap-ansi": "^10.0.0",
    "youtube-transcript": "^1.3.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.14",
    "eslint": "^9.39.2",
    "jsdom": "^27.4.0",
    "memfs": "^4.56.11",
    "playwright": "^1.57.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
