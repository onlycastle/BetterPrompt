{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": true,
    "paths": {
      "@/*": ["../src/*"]
    },
    "baseUrl": ".."
  },
  "include": ["./**/*.ts", "../src/lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
