{
  "name": "no-ai-slop",
  "version": "0.4.0",
  "description": "Analyze your AI collaboration style with Claude Code",
  "type": "module",
  "bin": {
    "no-ai-slop": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
