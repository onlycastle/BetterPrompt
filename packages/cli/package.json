  "repository": {
    "type": "git",
    "url": "https://github.com/nomoreaislop/nomoreaislop"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "ora": "^8.1.1",
    "boxen": "^8.0.1"
  }
}
