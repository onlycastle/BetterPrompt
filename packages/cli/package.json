{
  "name": "betterprompt-cli",
  "version": "0.9.36",
  "description": "See your AI anti-patterns in Claude Code sessions",
  "type": "module",
  "bin": {
    "betterprompt-cli": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "release": "./scripts/publish.sh",
    "release:patch": "./scripts/publish.sh patch",
    "release:minor": "./scripts/publish.sh minor",
    "release:major": "./scripts/publish.sh major"
  },
  "keywords": [
    "betterprompt",
    "claude",
    "claude-code",
    "ai",
    "collaboration",
    "developer-tools",
    "productivity",
    "analysis",
    "slop"
  ],
  "author": "BetterPrompt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/onlycastle/BetterPrompt"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "cli-cursor": "^5.0.0",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "keytar": "^7.9.0",
    "log-update": "^6.1.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "string-width": "^7.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
