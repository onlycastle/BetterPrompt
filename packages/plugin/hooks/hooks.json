{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/hooks/session-start-handler.js",
            "description": "Inject queued BetterPrompt auto-analysis context at session start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Read",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/hooks/pre-tool-use-handler.js",
            "description": "Auto-approve BetterPrompt CLI commands and plugin data file operations"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/hooks/post-session-handler.js",
            "description": "Queue BetterPrompt auto-analysis when enough new sessions accumulate"
          }
        ]
      }
    ]
  }
}
